<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Página Principal</title>
    <style>
        /* Estilos Generales */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial', sans-serif;
        }

        body {
            background-color: #f5f5f5;
            color: #333;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Barra de Navegación Superior */
        header {
            background-color: #803376; /* El tono morado de la imagen */
            color: white;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Simulación de la foto de perfil redonda/cuadrada pequeña de la esquina */
        .profile-img {
            width: 35px;
            height: 35px;
            border-radius: 5px;
            background-color: #ddd;
            object-fit: cover;
            border: 1px solid white;
        }

        /* Menú de enlaces */
        .nav-links {
            display: flex;
            list-style: none;
            gap: 15px;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: bold;
            transition: opacity 0.2s;
            cursor: pointer;
        }

        .nav-links a:hover {
            opacity: 0.8;
        }

        /* Botón de Menú */
        .menu-btn {
            background-color: white;
            color: #803376;
            border: none;
            padding: 5px 12px;
            border-radius: 15px;
            font-size: 0.85rem;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
        }

        .menu-btn:hover {
            background-color: #f0f0f0;
        }

        /* Contenido Principal */
        main {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            background-color: white;
            max-width: 800px;
            margin: 20px auto;
            width: 90%;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

        .welcome-title {
            color: #803376;
            font-size: 2.5rem;
            font-weight: 900;
            letter-spacing: 2px;
            margin-bottom: 20px;
            text-align: center;
        }

        /* Contenedor de la Imagen del Spiderman animado */
        .image-container {
            max-width: 350px;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .image-container img {
            width: 100%;
            height: auto;
            object-fit: contain;
        }

        /* Pie de página morado como el de la foto */
        footer {
            background-color: #803376;
            color: rgba(255, 255, 255, 0.8);
            text-align: right;
            padding: 5px 20px;
            font-size: 0.75rem;
            width: 100%;
        }

        /* Adaptabilidad para Celulares (Responsive) */
        @media (max-width: 600px) {
            .nav-links {
                display: none; /* Se oculta en móviles y se maneja con el botón */
                flex-direction: column;
                position: absolute;
                top: 55px;
                right: 20px;
                background-color: #803376;
                padding: 15px;
                border-radius: 8px;
                box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            }

            .nav-links.show {
                display: flex;
            }
        }
    </style>
</head>
<body>

    <header>
        <div class="nav-left">
            <img src="chichichivaschivas.jpg" alt="Perfil" class="profile-img">
        </div>
        
        <ul class="nav-links" id="navLinks">
            <li><a href="inicio.html">Inicio</a></li>
            <li><a href="biografia.html">Biografía</a></li>
            <li><a href="cv3.html">CV</a></li>
            <li><a href="proyectos.html">Proyectos</a></li>
            <li><a href="orientacion.html">Orientación</a></li>
            <li><a href="galeria.html">Galería</a></li>
            <li><a href="contacto.html">Contactos</a></li>
        </ul>

        <button class="menu-btn" id="menuBtn">Menú</button>
    </header>

    <main>
        <div id="inicio">
            <h1 class="welcome-title">BIENVENIDOS</h1>
            <div class="image-container">
                <img src="spiderjaja.jpg" alt="Spiderman colgando de cabeza">
            </div>
        </div>
    </main>

    <footer>
        MORENO CRUZ EDWIN - 3II
    </footer>

    <script>
        const menuBtn = document.getElementById('menuBtn');
        const navLinks = document.getElementById('navLinks');

        menuBtn.addEventListener('click', () => {
            navLinks.classList.toggle('show');
        });
    </script>
</body>
</html>
